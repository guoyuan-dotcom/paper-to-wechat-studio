# Research Workbench Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenClaw Gateway URL
OPENCLAW_GATEWAY=http://localhost:18790

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Database (SQLite for development)
DATABASE_URL=./data/research_workbench.db

# Logging
LOG_LEVEL=info

# Kimi / Moonshot
# The app now expects the user to enter the API key in the frontend UI.
# Keep this blank for public repos.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_METADATA_MODEL=moonshot-v1-8k
KIMI_WRITING_MODEL=moonshot-v1-32k
KIMI_ALLOW_LOCAL_FALLBACK=false
